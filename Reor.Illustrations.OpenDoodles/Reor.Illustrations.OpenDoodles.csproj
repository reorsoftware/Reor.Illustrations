<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        
        <Authors>Jake Bailey-Saltmarsh</Authors>
        <Company>Reor</Company>
        
        <Title>Reor Illustrations: OpenDoodles</Title>
        <Description>
            This Reor Illustrations package makes Pablo Stanley's OpenDoodles available in the dotnet ecosystem. Each doodle can be customised and are exposed with a sensible default for easy use.
        </Description>
        
        <PackageId>Reor.Illustrations.OpenDoodles</PackageId>
        <PackageTags>OpenDoodles;Doodles;SVG;Reor;Illustrations;Illustration;graphics;vector;ui;design;artwork</PackageTags>
        <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        
    </PropertyGroup>
    <ItemGroup>
        <None Include="docs\README.md" Pack="true" PackagePath="\"/>
    </ItemGroup>
</Project>
